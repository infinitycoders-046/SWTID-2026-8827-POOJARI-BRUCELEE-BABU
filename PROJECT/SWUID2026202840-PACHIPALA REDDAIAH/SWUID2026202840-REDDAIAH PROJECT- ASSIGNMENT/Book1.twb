      <aliases enabled='yes' />
      <column caption='season' datatype='string' name='[Calculation_0464557844803591]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='CASE DATEPART(&apos;month&apos;, [Calculation_0464557845843976])&#13;&#10;    WHEN 12 THEN &quot;Winter&quot;&#13;&#10;    WHEN 1 THEN &quot;Winter&quot;&#13;&#10;    WHEN 2 THEN &quot;Winter&quot;&#13;&#10;    WHEN 3 THEN &quot;Spring&quot;&#13;&#10;    WHEN 4 THEN &quot;Spring&quot;&#13;&#10;    WHEN 5 THEN &quot;Spring&quot;&#13;&#10;    WHEN 6 THEN &quot;Summer&quot;&#13;&#10;    WHEN 7 THEN &quot;Summer&quot;&#13;&#10;    WHEN 8 THEN &quot;Summer&quot;&#13;&#10;    WHEN 9 THEN &quot;Fall&quot;&#13;&#10;    WHEN 10 THEN &quot;Fall&quot;&#13;&#10;    WHEN 11 THEN &quot;Fall&quot;&#13;&#10;END' />
      </column>
      <column caption='Date' datatype='date' name='[Calculation_0464557845843976]' role='dimension' type='ordinal'>
        <calculation class='tableau' formula='DATE(STR([Year]) + &quot;-01-01&quot;)' />
      </column>
      <column caption='zero' datatype='integer' name='[Calculation_0464557910941706]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='0' />
      </column>
      <column caption='Unit type' datatype='string' name='[Calculation_0464557913079820]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Crop] = &quot;Rice&quot; THEN &quot;Kharif&quot;&#13;&#10;&#13;&#10;ELSEIF [Crop] = &quot;Maize&quot; THEN &quot;Kharif&quot;&#13;&#10;&#13;&#10;ELSEIF [Crop] = &quot;Cotton&quot; THEN &quot;Kharif&quot;&#13;&#10;&#13;&#10;ELSEIF [Crop] = &quot;Groundnut&quot; THEN &quot;Kharif&quot;&#13;&#10;&#13;&#10;ELSEIF [Crop] = &quot;Wheat&quot; THEN &quot;Rabi&quot;&#13;&#10;&#13;&#10;ELSEIF [Crop] = &quot;Barley&quot; THEN &quot;Rabi&quot;&#13;&#10;&#13;&#10;ELSEIF [Crop] = &quot;Gram&quot; THEN &quot;Rabi&quot;&#13;&#10;&#13;&#10;ELSEIF [Crop] = &quot;Mustard&quot; THEN &quot;Rabi&quot;&#13;&#10;&#13;&#10;ELSEIF [Crop] = &quot;Potato&quot; THEN &quot;Winter&quot;&#13;&#10;&#13;&#10;ELSEIF [Crop] = &quot;Peas &amp; beans (Pulses)&quot; THEN &quot;Winter&quot;&#13;&#10;&#13;&#10;ELSEIF [Crop] = &quot;Watermelon&quot; THEN &quot;Summer&quot;&#13;&#10;&#13;&#10;ELSEIF [Crop] = &quot;Muskmelon&quot; THEN &quot;Summer&quot;&#13;&#10;&#13;&#10;ELSE &quot;Whole Year&quot;&#13;&#10;&#13;&#10;END' />
      </column>
      <column caption='min 1' datatype='real' name='[Calculation_0464557916467213]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='MIN([Area], [Production])' />
      </column>
      <column datatype='string' name='[Crop]' role='dimension' type='nominal' />
      <column datatype='string' name='[State]' role='dimension' semantic-role='[State].[Name]' type='nominal' />
      <column caption='Sheet1' datatype='table' name='[__tableau_internal_object_id__].[Sheet1_DA6E3397E80C46A988085960249362AD]' role='measure' type='quantitative' />
      <column-instance column='[Calculation_0464557844803591]' derivation='None' name='[none:Calculation_0464557844803591:nk]' pivot='key' type='nominal' />
