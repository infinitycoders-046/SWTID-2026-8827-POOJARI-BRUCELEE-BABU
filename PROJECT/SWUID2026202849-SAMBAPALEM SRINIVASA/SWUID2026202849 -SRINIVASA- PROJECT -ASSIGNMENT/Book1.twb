      <aliases enabled='yes' />
      <column caption='Date' datatype='date' name='[Calculation_0435970543882241]' role='dimension' type='ordinal'>
        <calculation class='tableau' formula='MAKEDATE(INT([Year]), 1, 1)' />
      </column>
      <column caption='season' datatype='string' name='[Calculation_0435970591289349]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF LEFT([Crop],1)=&quot;R&quot; THEN &quot;Kharif&quot;&#13;&#10;&#13;&#10;ELSEIF LEFT([Crop],1)=&quot;W&quot; THEN &quot;Rabi&quot;&#13;&#10;&#13;&#10;ELSEIF LEFT([Crop],1)=&quot;M&quot; THEN &quot;Summer&quot;&#13;&#10;&#13;&#10;ELSEIF LEFT([Crop],1)=&quot;A&quot; THEN &quot;Autumn&quot;&#13;&#10;&#13;&#10;ELSE &quot;Whole Year&quot;&#13;&#10;&#13;&#10;END' />
      </column>
      <column caption='zero' datatype='integer' name='[Calculation_0435970608623622]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='0' />
      </column>
      <column caption='unit type' datatype='string' name='[Calculation_0435970608791559]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Crop] = &quot;Rice&quot; THEN &quot;Kharif&quot;&#13;&#10;&#13;&#10;ELSEIF [Crop] = &quot;Maize&quot; THEN &quot;Kharif&quot;&#13;&#10;&#13;&#10;ELSEIF [Crop] = &quot;Cotton&quot; THEN &quot;Kharif&quot;&#13;&#10;&#13;&#10;ELSEIF [Crop] = &quot;Groundnut&quot; THEN &quot;Kharif&quot;&#13;&#10;&#13;&#10;ELSEIF [Crop] = &quot;Wheat&quot; THEN &quot;Rabi&quot;&#13;&#10;&#13;&#10;ELSEIF [Crop] = &quot;Barley&quot; THEN &quot;Rabi&quot;&#13;&#10;&#13;&#10;ELSEIF [Crop] = &quot;Gram&quot; THEN &quot;Rabi&quot;&#13;&#10;&#13;&#10;ELSEIF [Crop] = &quot;Mustard&quot; THEN &quot;Rabi&quot;&#13;&#10;&#13;&#10;ELSEIF [Crop] = &quot;Potato&quot; THEN &quot;Winter&quot;&#13;&#10;&#13;&#10;ELSEIF [Crop] = &quot;Peas &amp; beans (Pulses)&quot; THEN &quot;Winter&quot;&#13;&#10;&#13;&#10;ELSEIF [Crop] = &quot;Watermelon&quot; THEN &quot;Summer&quot;&#13;&#10;&#13;&#10;ELSEIF [Crop] = &quot;Muskmelon&quot; THEN &quot;Summer&quot;&#13;&#10;&#13;&#10;ELSE &quot;Whole Year&quot;&#13;&#10;&#13;&#10;END' />
      </column>
      <column caption='min 1' datatype='real' name='[Calculation_0435970615484424]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='MIN([Area], [Production])' />
      </column>
