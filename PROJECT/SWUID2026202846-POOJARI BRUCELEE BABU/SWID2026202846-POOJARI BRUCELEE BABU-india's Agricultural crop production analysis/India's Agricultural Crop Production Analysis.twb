      <aliases enabled='yes' />
      <column datatype='real' default-format='*' name='[Area]' role='measure' type='quantitative' />
      <column caption='unit type' datatype='string' name='[Calculation_0340310327812096]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Production] &lt; 1000000 THEN &quot;Low&quot;&#13;&#10;ELSEIF [Production] &lt; 10000000 THEN &quot;Medium&quot;&#13;&#10;ELSE &quot;High&quot;&#13;&#10;END' />
      </column>
      <column caption='Total Production' datatype='real' name='[Calculation_0340310360838151]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Production])' />
      </column>
      <column caption='Production (Crores)' datatype='real' name='[Calculation_1144328073859073]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='ROUND([Production] / 10000000, 2)' />
      </column>
